# ---------------------------------------------------------------------------
# Airflow environment variables
# Copy to .env and customise before running docker-compose up
# ---------------------------------------------------------------------------

# Airflow core
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW__WEBSERVER__SECRET_KEY=supersecretkey

# Postgres (used by Airflow metadata DB)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# AWS – update these to match your terraform outputs / environment
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=bigdata-project-data-lake

# If running on EC2 with an IAM instance profile, leave these empty.
# If running locally, set your credentials here:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

